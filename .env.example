# Copy this file to .env for local-only settings.
# Do not commit real tokens, cookies, account names, private URLs, or local absolute paths.
# 将此文件复制到 .env 以设置本地专用配置。
# 请勿提交真实的令牌、Cookie、账户名、私有 URL 或本地绝对路径。

DATA_DIR=data
MODEL_DIR=models
OUTPUT_DIR=outputs

# Optional: only needed if a public dataset or model download requires authentication.
# 可选：仅当下载公共数据集或模型需要身份验证时才需要。
HF_TOKEN=

# Optional crawler settings for public pages only. Never store login cookies here.
# 可选：仅适用于公共页面的可选爬虫设置。切勿在此处存储登录 Cookie。
CRAWL_USER_AGENT=NetContentSecurityCourseProject/0.1
CRAWL_DELAY_SECONDS=2
